# === GITHUB SECRETS A CONFIGURER ===
# Allez dans Settings > Secrets and variables > Actions > New repository secret

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Registry Docker Prive ---
# Adresse du registry (ex: 51.44.XX.XX:443)
REGISTRY_URL=<IP_REGISTRY>:443
# Identifiants de connexion au registry (htpasswd)
REGISTRY_USER=admin
REGISTRY_PASSWORD=admin123

# --- Base de donnees MySQL ---
MYSQL_PASSWORD=<mot_de_passe_root_mysql>
MYSQL_DATABASE=ynov_ci
MYSQL_USER=root
MYSQL_HOST=db

# --- Authentification applicative (frontend) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# --- URL de l'API backend utilisee par le frontend ---
# Renseignez l'IP publique de l'EC2 applicative (ex: http://15.188.XX.XX:8000)
# Ou laissez vide si defini dynamiquement
API_URL=http://<IP_APP>:8000
